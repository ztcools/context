# ---- Embedding (Ollama on this host) ----
EMBEDDING_PROVIDER=Ollama
OLLAMA_HOST=http://10.50.4.149:11435
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# ---- Vector DB (Milvus on this host) ----
MILVUS_ADDRESS=10.50.4.149:19530
MILVUS_TOKEN=

# ---- Git incremental / layered / embedding cache ----
EMBEDDING_CACHE_ENABLED=true
GIT_INCREMENTAL_ENABLED=true
GIT_LAYERED_ENABLED=true
GIT_DELTA_MAX_FILES=2000

# ---- Index service scheduling ----
GIT_INDEX_SOURCE=config
GIT_INDEX_WORKDIR=/workdir/repos
GIT_INDEX_RUN_ON_START=true
GIT_INDEX_DAILY_HOUR=3
GIT_INDEX_HTTP_PORT=8790

# ---- Repositories to keep indexed (canonical URL MUST match developers' origin) ----
# JSON array. token optional for private GitLab (uses oauth2 https auth).
GIT_INDEX_REPOS=[{"name":"my-repo","url":"https://gitlab.example.com/group/my-repo.git","branch":"main","token":"REPLACE_WITH_TOKEN"}]

# ---- Alternative: auto-discover from GitLab API (set GIT_INDEX_SOURCE=gitlab) ----
# GITLAB_BASE_URL=https://gitlab.example.com
# GITLAB_TOKEN=REPLACE_WITH_TOKEN
# GITLAB_GROUP=my-group
# GITLAB_PROJECT_IDS=
# GITLAB_DEFAULT_BRANCH=main
