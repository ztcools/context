# Claude Context Environment Variables Example
# 
# Copy this file to ~/.context/.env as a global setting, modify the values as needed
#
# Usage: cp env.example ~/.context/.env
#
# Note: This file does not work if you put it in your codebase directory (because it may conflict with the environment variables of your codebase project)

# =============================================================================
# Embedding Provider Configuration
# =============================================================================

# Embedding provider: OpenAI, VoyageAI, Gemini, Ollama
EMBEDDING_PROVIDER=OpenAI

# Embedding model (provider-specific)
EMBEDDING_MODEL=text-embedding-3-small

# Embedding batch size for processing (default: 100)
# You can customize it according to the throughput of your embedding model. Generally, larger batch size means less indexing time.
EMBEDDING_BATCH_SIZE=100

# --- Team-version incremental indexing (Git + Embedding dedup) ---
# Content-hash embedding cache: reuse vectors for identical chunk content across
# branches / developers / re-indexes, so each unique chunk is embedded only once.
# Backed by a shared Milvus collection (embedding_cache_<model>_<dim>). Default: true.
# EMBEDDING_CACHE_ENABLED=true

# Git-driven incremental indexing: on re-index, diff the last-indexed commit
# against HEAD and process only changed files instead of rescanning the repo.
# Commit state is tracked in a shared Milvus collection (code_index_state).
# Non-git repositories transparently fall back to a full index. Default: true.
# GIT_INCREMENTAL_ENABLED=true

# Git-DAG layered indexing: a branch cut from an already-indexed root (main) stores
# only its diff vs main (added/modified files); search composes exactly two layers
# — main ⊕ this branch's diff — so results always reflect the whole project plus the
# branch's changes. The immediate parent branch is tracked separately for the branch
# tree (A ← B ← C). main/root branches are indexed in full. Default: true.
# GIT_LAYERED_ENABLED=true
# Max changed-files-vs-main before a branch falls back to a full index (guards the
# query-time mask filter from growing unbounded). Default: 2000.
# GIT_DELTA_MAX_FILES=2000

# --- Cloud Git Index Service (packages/git-index-service) ---
# Scheduled server that fetches main repositories from GitLab and incrementally
# indexes them (git diff → chunk → embedding cache → Milvus). Reuses all embedding
# and Milvus config above. Runs alongside the MCP server; developers' branches
# reuse the shared index it produces.
#
# Repo source: 'config' (GIT_INDEX_REPOS below) or 'gitlab' (GitLab API discovery).
# GIT_INDEX_SOURCE=config
# GIT_INDEX_REPOS=[{"name":"acme/app","url":"https://gitlab.example.com/acme/app.git","branch":"main","token":"glpat-xxx"}]
# Working directory for local mirrors (default: ~/.claude-context/git-index-repos)
# GIT_INDEX_WORKDIR=/var/lib/claude-context/repos
# Schedule: daily at hour (0-23) OR fixed interval in ms. Daily takes precedence.
# GIT_INDEX_DAILY_HOUR=3
# GIT_INDEX_INTERVAL_MS=86400000
# Run one pass immediately on startup (default: true)
# GIT_INDEX_RUN_ON_START=true
# One-shot mode: run a single pass then exit (for external cron/CI drivers)
# GIT_INDEX_RUN_ONCE=false
# Optional HTTP control surface (GET /health, POST /index). Unset = disabled.
# GIT_INDEX_HTTP_PORT=8790
#
# GitLab API discovery (when GIT_INDEX_SOURCE=gitlab):
# GITLAB_BASE_URL=https://gitlab.example.com
# GITLAB_TOKEN=glpat-xxx
# GITLAB_GROUP=my-group                 # index every project under a group (incl. subgroups)
# GITLAB_PROJECT_IDS=123,456            # or an explicit project id list
# GITLAB_DEFAULT_BRANCH=main

# =============================================================================
# OpenAI Configuration
# =============================================================================

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI base URL (optional, for custom endpoints)
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# VoyageAI Configuration
# =============================================================================

# VoyageAI API key
# VOYAGEAI_API_KEY=your-voyageai-api-key-here

# =============================================================================
# Gemini Configuration
# =============================================================================

# Google Gemini API key
# GEMINI_API_KEY=your-gemini-api-key-here

# Gemini API base URL (optional, for custom endpoints)
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# =============================================================================
# Ollama Configuration
# =============================================================================

# Ollama model name
# OLLAMA_MODEL=

# Ollama host (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Vector Database Configuration (Milvus/Zilliz)
# =============================================================================

# Milvus server address. It's optional when you get Zilliz Personal API Key.
MILVUS_ADDRESS=your-zilliz-cloud-public-endpoint

# Milvus authentication token. You can refer to this guide to get Zilliz Personal API Key as your Milvus token.
# https://github.com/zilliztech/claude-context/blob/master/assets/signup_and_get_apikey.png
MILVUS_TOKEN=your-zilliz-cloud-api-key


# =============================================================================
# Code Splitter Configuration
# =============================================================================

# Code splitter type: ast, langchain
SPLITTER_TYPE=ast

# =============================================================================
# Custom File Processing Configuration
# =============================================================================

# Additional file extensions to include beyond defaults (comma-separated)
# Example: .vue,.svelte,.astro,.twig,.blade.php
# CUSTOM_EXTENSIONS=.vue,.svelte,.astro

# Additional ignore patterns to exclude files/directories (comma-separated)
# Example: temp/**,*.backup,private/**,uploads/**
# CUSTOM_IGNORE_PATTERNS=temp/**,*.backup,private/**

# Whether to use hybrid search mode. If true, it will use both dense vector and BM25; if false, it will use only dense vector search.
# HYBRID_MODE=true

# =============================================================================
# Search Precision / Token Tuning (optional)
# =============================================================================
# These knobs tune the read-vs-search tradeoff. Defaults favor precise,
# token-lean context. All are optional; omit to use defaults.

# Fallback result count when the search caller omits `limit` (1-50).
# SEARCH_DEFAULT_LIMIT=10

# Minimum cosine score. Only applies to the dense (non-hybrid) path;
# ignored in hybrid/RRF mode (use SEARCH_SCORE_RATIO there).
# SEARCH_THRESHOLD=0.3

# Per-snippet character cap (~4 chars/token). Lower = leaner context.
# Default 2500 (~625 tokens); was 5000.
# SEARCH_SNIPPET_MAX_CHARS=2500

# Relative tail cutoff in [0,1]: drop results scoring below ratio×topScore.
# Works in BOTH dense and hybrid modes since it's relative. 0 = disabled.
# The top result is always kept. Try 0.5 for tighter, more precise results.
# SEARCH_SCORE_RATIO=0
